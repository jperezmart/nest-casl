{
  "name": "@jperezmart/nest-casl",
  "version": "0.0.0",
  "description": "Modern CASL authorization for NestJS — REST-focused, ESM + CJS, CASL v6.",
  "author": "Javier Pérez Martín <javier.perez.martin97@gmail.com>",
  "license": "MIT",
  "keywords": [
    "nestjs",
    "nest",
    "casl",
    "authorization",
    "permissions",
    "abilities",
    "rbac",
    "abac",
    "guard",
    "rest"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jperezmart/nest-casl.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/jperezmart/nest-casl/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/jperezmart/nest-casl/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@casl/ability": "^7.0.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@casl/ability": "^7.0.0",
    "@nestjs/common": "^11.1.26",
    "@nestjs/core": "^11.1.26",
    "@types/node": "^24.13.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
