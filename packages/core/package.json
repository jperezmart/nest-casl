{
  "name": "@jperezmart/nest-casl",
  "version": "0.0.0",
  "description": "Modern CASL authorization for NestJS — REST-focused, ESM + CJS, CASL v7.",
  "keywords": [
    "nestjs",
    "nest",
    "casl",
    "authorization",
    "permissions",
    "abilities",
    "rbac",
    "abac",
    "guard",
    "rest"
  ],
  "homepage": "https://github.com/jperezmart/nest-casl/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/jperezmart/nest-casl/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jperezmart/nest-casl.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "author": "Javier Pérez Martín <javier.perez.martin97@gmail.com>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@casl/ability": "catalog:",
    "@jperezmart/eslint-config": "workspace:*",
    "@jperezmart/typescript-config": "workspace:*",
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "@nestjs/testing": "catalog:",
    "@types/node": "catalog:",
    "@types/supertest": "catalog:",
    "eslint": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:",
    "supertest": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@casl/ability": "^7.0.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
