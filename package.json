{
  "name": "nest-casl-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for @jperezmart/nest-casl — modern CASL integration for NestJS (REST)",
  "license": "MIT",
  "author": "Javier Pérez Martín <javier.perez.martin97@gmail.com>",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "clean": "turbo run clean && rm -rf node_modules",
    "dev": "turbo run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "release": "turbo run build && changeset publish",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@jperezmart/eslint-config": "workspace:*",
    "prettier": "catalog:",
    "prettier-plugin-packagejson": "catalog:",
    "prettier-plugin-sort-json": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  }
}
