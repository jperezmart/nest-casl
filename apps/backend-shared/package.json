{
  "name": "backend-shared",
  "version": "0.0.0",
  "private": true,
  "description": "Example NestJS REST app — @jperezmart/nest-casl with permissions, subjects and types imported from a shared package.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "dev": "nest start --watch",
    "lint": "eslint .",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@casl/ability": "catalog:",
    "@jperezmart/example-shared": "workspace:*",
    "@jperezmart/nest-casl": "workspace:*",
    "@nestjs/common": "catalog:",
    "@nestjs/core": "catalog:",
    "@nestjs/platform-express": "catalog:",
    "reflect-metadata": "catalog:",
    "rxjs": "catalog:"
  },
  "devDependencies": {
    "@jperezmart/eslint-config": "workspace:*",
    "@jperezmart/typescript-config": "workspace:*",
    "@nestjs/cli": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:"
  }
}
