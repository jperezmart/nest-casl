{
  "name": "example-rest",
  "version": "0.0.0",
  "private": true,
  "description": "Example NestJS REST app showcasing @jperezmart/nest-casl.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@casl/ability": "^7.0.0",
    "@jperezmart/nest-casl": "workspace:*",
    "@nestjs/common": "^11.1.26",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-express": "^11.1.26",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@types/node": "^24.13.2",
    "typescript": "^6.0.3"
  }
}
